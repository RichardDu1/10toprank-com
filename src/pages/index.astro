---
// Root path — returns 200 with canonical pointing to /en/ (CRITICAL: no redirect)
// Per BUILD_GUIDE.md Section V
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import Card from '../components/Card.astro';

const pageTitle = '10 Top Rank — Expert Curated Top 10 Lists';
const pageDescription = 'Wirecutter-style in-depth reviews and top 10 rankings for consumer tech and software.';
---

<BaseLayout
  title={pageTitle}
  description={pageDescription}
  canonical="https://10toprank.com/en/"
  schema={{
    type: 'WebSite',
    data: { description: pageDescription },
  }}
>
  <Hero
    title="The Definitive Top 10 Rankings"
    subtitle="We spend 500+ hours testing so you don't have to."
    cta={{ label: 'Explore Tools', href: '/en/categories/' }}
    ctaSecondary={{ label: 'Latest Reviews', href: '/en/latest/' }}
  />

  <!-- Featured Categories -->
  <section class="container py-16">
    <h2 class="text-2xl font-bold mb-8 text-center">Popular Categories</h2>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
      <Card
        title="Home Tech"
        description="Smart Home Rankings"
        href="/en/categories/writing/"
        tag="Popular"
      />
      <Card
        title="Laptops"
        description="Top 10 Work Laptops"
        href="/en/categories/image/"
        tag="Trending"
      />
      <Card
        title="Headphones"
        description="Top 10 Noise Cancelling"
        href="/en/categories/coding/"
        tag="Essential"
      />
      <Card
        title="Software"
        description="Top 10 Antivirus"
        href="/en/categories/productivity/"
        tag="New"
      />
    </div>
  </section>

  <!-- Latest Reviews -->
  <section class="bg-neutral py-16">
    <div class="container">
      <h2 class="text-2xl font-bold mb-8 text-center">Latest Updates</h2>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        <Card
          title="Top 10 Laptops of 2026"
          description="Is ChatGPT still the best AI assistant? Our honest review after 2+ years of daily use"
          href="/en/reviews/chatgpt/"
          rating={4.5}
          price="Free"
        />
        <Card
          title="Top 10 Wireless Earbuds"
          description="Side-by-side comparison of the top two AI assistants — which one wins?"
          href="/en/compare/claude-vs-chatgpt/"
          rating={4.7}
          price="Free"
        />
        <Card
          title="Top 10 Mechanical Keyboards"
          description="The latest Midjourney update raises the bar for AI image generation again"
          href="/en/reviews/midjourney-v7/"
          rating={4.8}
          price="10"
        />
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="container py-16 text-center">
    <h2 class="text-2xl font-bold mb-4">Don't Know Which AI Tool to Pick?</h2>
    <p class="text-muted mb-6 max-w-xl mx-auto">Use our AI Tool Finder to get personalized recommendations based on your needs.</p>
    <a href="/en/finder/" class="inline-flex items-center px-8 py-3 bg-primary text-white font-semibold rounded-lg hover:bg-primary-dark transition-colors">
      Try the AI Tool Finder →
    </a>
  </section>
</BaseLayout>
