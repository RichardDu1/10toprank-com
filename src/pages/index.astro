---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import Card from '../components/Card.astro';

const pageTitle = '10 Top Rank — Expert Curated Top 10 Lists';
const pageDescription = 'Wirecutter-style in-depth reviews and top 10 rankings for consumer tech and software.';
---

<BaseLayout
  title={pageTitle}
  description={pageDescription}
  canonical="https://10toprank.com/en/"
  schema={{ type: 'WebSite', data: { description: pageDescription } }}
>
  <Hero title="The Definitive Top 10 Rankings" subtitle="We spend 500+ hours testing so you don't have to." />

  <section class="container mx-auto px-6 py-8 animate-fade-in-up" style="animation-delay: 0.2s;">
    <h2 class="text-xl md:text-2xl font-bold mb-10 text-white tracking-tight flex items-center gap-3">
      <span class="w-1.5 h-6 bg-primary-500 rounded-full"></span>
      Popular Categories
    </h2>
    <div class="grid grid-cols-1 md:grid-cols-3 lg:grid-cols-4 gap-6 auto-rows-fr">
      <Card title="Home Tech" description="Smart Home Rankings" href="/en/categories/c1/" tag="Trending" featured={true} />
      <Card title="Laptops" description="Top 10 Work Laptops" href="/en/categories/c2/" tag="New" />
      <Card title="Headphones" description="Top 10 Noise Cancelling" href="/en/categories/c3/" />
      <Card title="Software" description="Top 10 Antivirus" href="/en/categories/c4/" />
    </div>
  </section>

  <section class="container mx-auto px-6 py-16 animate-fade-in-up" style="animation-delay: 0.4s;">
    <h2 class="text-xl md:text-2xl font-bold mb-10 text-white tracking-tight flex items-center gap-3">
      <span class="w-1.5 h-6 bg-purple-500 rounded-full"></span>
      Latest Updates
    </h2>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
      <Card title="Top 10 Laptops of 2026" description="Read our latest in-depth review and analysis for 2026." href="/en/reviews/1/" rating={4.9} price="Verified" />
      <Card title="Top 10 Wireless Earbuds" description="A comprehensive breakdown of features, pricing, and pros/cons." href="/en/reviews/2/" rating={4.7} price="Top Choice" />
      <Card title="Top 10 Mechanical Keyboards" description="Everything you need to know before making a decision." href="/en/reviews/3/" rating={4.5} price="Updated" />
    </div>
  </section>
</BaseLayout>
