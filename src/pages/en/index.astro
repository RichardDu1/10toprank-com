---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

// Fetch all reviews and sort by rating
const allReviews = await getCollection('reviews');
const sortedReviews = allReviews.sort((a, b) => b.data.rating - a.data.rating);

// Get top 3 featured
const featuredReviews = sortedReviews.slice(0, 3);

const pageTitle = 'Deep-Dive B2B Software Reviews | 10TopRank';
const pageDescription = 'Exhaustively tested, objectively ranked B2B software. We spend hundreds of hours researching so you don\'t have to.';
---

<BaseLayout
  title={pageTitle}
  description={pageDescription}
  canonical="https://10toprank.com/en/"
  schema={{ type: 'WebSite', data: { description: pageDescription } }}
>
  <main class="max-w-[1200px] mx-auto px-6 pt-32 pb-24">
    <!-- Hero Section -->
    <header class="text-center mb-24">
      <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-white/5 border border-white/10 text-gray-300 text-sm mb-8">
        <span class="w-2 h-2 rounded-full bg-green-500 animate-pulse"></span>
        Deep-Dive B2B Review Engine
      </div>
      
      <h1 class="text-5xl md:text-7xl font-bold leading-[1.1] tracking-tight mb-8">
        Stop guessing. <br/>
        <span class="text-transparent bg-clip-text bg-gradient-to-r from-purple-400 to-blue-400 italic">Deploy with data.</span>
      </h1>
      
      <p class="text-xl text-gray-400 font-light max-w-2xl mx-auto leading-relaxed mb-12">
        We buy, test, and rank enterprise software, marketing tools, and AI solutions. Zero sponsored placements. 100% objective data.
      </p>

      <div class="flex flex-col sm:flex-row justify-center gap-4">
        <a href="/en/reviews/" class="bg-white text-black px-8 py-4 rounded-xl font-bold hover:bg-gray-200 transition-colors">
          Browse All Reviews
        </a>
        <a href="#categories" class="glass-panel text-white px-8 py-4 rounded-xl font-bold hover:bg-white/10 transition-colors">
          Explore Categories
        </a>
      </div>
    </header>

    <!-- Top Ranked Spotlight -->
    {featuredReviews.length > 0 && (
      <section class="mb-24">
        <div class="flex items-center justify-between mb-8">
          <h2 class="text-3xl font-bold">Highest Rated This Month</h2>
        </div>
        
        <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
          {featuredReviews.map((review, index) => (
            <a href={`/en/reviews/${review.id.split('/').pop()}`} class="glass-panel rounded-2xl p-6 hover:-translate-y-1 transition-transform group relative overflow-hidden">
              {index === 0 && (
                <div class="absolute top-0 right-0 bg-yellow-500 text-black text-xs font-bold px-3 py-1 rounded-bl-lg z-10">
                  #1 Editor's Choice
                </div>
              )}
              <div class="flex justify-between items-start mb-4">
                <span class="text-xs font-medium px-2 py-1 rounded bg-white/10 text-gray-300">
                  {review.data.category}
                </span>
                <span class="text-lg font-bold text-yellow-400">
                  ★ {review.data.rating.toFixed(1)}
                </span>
              </div>
              <h3 class="text-2xl font-bold mb-2 group-hover:text-purple-400 transition-colors">{review.data.title}</h3>
              <p class="text-gray-400 text-sm mb-4 line-clamp-2">{review.data.description}</p>
              <div class="text-xs text-gray-500">Target: {review.data.targetAudience}</div>
            </a>
          ))}
        </div>
      </section>
    )}

    {allReviews.length === 0 && (
      <div class="text-center py-24 glass-panel rounded-2xl">
        <h3 class="text-2xl font-bold text-gray-400">Review engine indexing...</h3>
        <p class="text-gray-500 mt-2">Our crawlers are currently analyzing B2B software.</p>
      </div>
    )}

  </main>
</BaseLayout>
