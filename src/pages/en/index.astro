---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

// Fetch all listicles and sort by date
const allListicles = await getCollection('listicles');
const sortedListicles = allListicles.sort((a, b) => new Date(b.data.lastUpdated).getTime() - new Date(a.data.lastUpdated).getTime());

// Get top 3 featured
const featuredListicles = sortedListicles.slice(0, 3);

const pageTitle = 'Deep-Dive B2B Software Reviews | 10TopRank';
const pageDescription = 'Exhaustively tested, objectively ranked B2B software. We spend hundreds of hours researching so you don\'t have to.';
---

<BaseLayout
  title={pageTitle}
  description={pageDescription}
  canonical="https://10toprank.com/en/"
  schema={{ type: 'WebSite', data: { description: pageDescription } }}
>
  <main class="max-w-[1200px] mx-auto px-6 pt-32 pb-24">
    <!-- Hero Section -->
    <header class="text-center mb-24">
      <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-white/5 border border-white/10 text-gray-300 text-sm mb-8">
        <span class="w-2 h-2 rounded-full bg-green-500 animate-pulse"></span>
        Deep-Dive B2B Review Engine
      </div>
      
      <h1 class="text-5xl md:text-7xl font-bold leading-[1.1] tracking-tight mb-8">
        Stop guessing. <br/>
        <span class="text-transparent bg-clip-text bg-gradient-to-r from-purple-400 to-blue-400 italic">Deploy with data.</span>
      </h1>
      
      <p class="text-xl text-gray-400 font-light max-w-2xl mx-auto leading-relaxed mb-12">
        We buy, test, and rank enterprise software, marketing tools, and AI solutions. Zero sponsored placements. 100% objective data.
      </p>

      <div class="flex flex-col sm:flex-row justify-center gap-4">
        <a href="/en/listicles/" class="bg-white text-black px-8 py-4 rounded-xl font-bold hover:bg-gray-200 transition-colors">
          Browse All Rankings
        </a>
        <a href="#categories" class="glass-panel text-white px-8 py-4 rounded-xl font-bold hover:bg-white/10 transition-colors">
          Explore Categories
        </a>
      </div>
    </header>

    <!-- Top Ranked Spotlight -->
    {featuredListicles.length > 0 && (
      <section class="mb-24">
        <div class="flex items-center justify-between mb-8">
          <h2 class="text-3xl font-bold">Highest Rated This Month</h2>
        </div>
        
        <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
          {featuredListicles.map((item, index) => (
            <a href={`/en/listicles/${item.id.split('/').pop()}`} class="glass-panel rounded-2xl p-6 hover:-translate-y-1 transition-transform group relative overflow-hidden">
              <div class="absolute top-0 right-0 bg-primary-500/20 text-primary-400 text-xs font-bold px-3 py-1 rounded-bl-lg">#{index + 1}</div>
              <div class="flex justify-between items-start mb-4">
                <span class="text-xs font-medium px-3 py-1 rounded-full bg-white/5 text-gray-300 border border-white/10 group-hover:border-primary-500/30 transition-colors">
                  {item.data.category}
                </span>
              </div>
              <h3 class="text-2xl font-bold mb-3 group-hover:text-primary-400 transition-colors leading-tight">{item.data.title}</h3>
              <p class="text-gray-400 text-sm line-clamp-3 mb-6">{item.data.description}</p>
              <div class="flex items-center gap-2 mt-auto">
                <span class="text-sm text-gray-500">Updated: {item.data.lastUpdated}</span>
              </div>
            </a>
          ))}
        </div>
      </section>
    )}

    {allListicles.length === 0 && (
      <div class="text-center py-24 glass-panel rounded-2xl">
        <h3 class="text-2xl font-bold text-gray-400">Review engine indexing...</h3>
        <p class="text-gray-500 mt-2">Our crawlers are currently analyzing B2B software.</p>
      </div>
    )}

  </main>
</BaseLayout>
