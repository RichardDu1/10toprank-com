---
import { getCollection } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';

const allListicles = await getCollection('listicles');
const sortedListicles = allListicles.sort((a, b) => new Date(b.data.lastUpdated).getTime() - new Date(a.data.lastUpdated).getTime());

const pageTitle = 'All Top 10 Rankings | 10TopRank';
const pageDescription = 'Browse all our in-depth top 10 rankings and product comparisons.';
---

<BaseLayout
  title={pageTitle}
  description={pageDescription}
  canonical="https://10toprank.com/en/listicles/"
>
  <main class="max-w-[1200px] mx-auto px-6 pt-32 pb-24">
    <header class="mb-16">
      <h1 class="text-5xl font-bold mb-6">Software Rankings</h1>
      <p class="text-xl text-gray-400 max-w-2xl">Discover our expert-curated top 10 lists.</p>
    </header>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
      {sortedListicles.length > 0 ? sortedListicles.map((item) => (
        <a href={`/en/listicles/${item.id.split('/').pop()}`} class="glass-panel rounded-xl p-6 hover:-translate-y-1 transition-transform group">
          <div class="flex justify-between items-start mb-4">
            <span class="text-xs font-medium px-2 py-1 rounded bg-white/10 text-gray-300">
              {item.data.category}
            </span>
          </div>
          <h3 class="text-xl font-bold mb-2 group-hover:text-purple-400 transition-colors">{item.data.title}</h3>
          <p class="text-gray-400 text-sm mb-4 line-clamp-2">{item.data.description}</p>
          <div class="text-xs text-gray-500">Updated: {item.data.lastUpdated}</div>
        </a>
      )) : (
        <div class="col-span-1 text-center py-12 glass-panel rounded-xl text-gray-400">
          No rankings found.
        </div>
      )}
    </div>
  </main>
</BaseLayout>
